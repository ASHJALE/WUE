# Copy this file to .env and replace each placeholder with local PostgreSQL values.
# URL-encode special characters in the username or password (for example, @ as %40).
DATABASE_URL=postgresql+psycopg://YOUR_USER:YOUR_PASSWORD@localhost:5432/wue_db

# Replace this development placeholder with a long, random secret in .env.
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60
